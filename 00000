<!-- Chosen Palette: Harmony Ocean (Fondo: #FDFBF9, Primario: #0A2E50, Acento: #4ECDC4, Contraste: #F27D52) -->
<!-- Application Structure Plan: 
    1. Hero Section: Visión estratégica y objetivos del relanzamiento.
    2. Panel Económico Interactivo: Gráfico de asignación de capital y Calculadora de Comisiones en tiempo real para proyectar el Success Fee del 5%.
    3. Hub de Operaciones (Zona Estéril): Desglose técnico de la infraestructura y el flujo logístico.
    4. Motor Digital: Explicación del embudo de ventas Automatizado (Ads -> Bot -> CRM).
    5. Protocolo de Calidad: Visualización de los pasos de curaduría y empaque.
    Por qué esta estructura: Se prioriza la claridad financiera y la eficiencia operativa para dar seguridad a la Dirección General sobre el retorno de inversión y la escalabilidad del modelo.
-->
<!-- Visualization & Content Choices:
    - Capital Allocation -> Proportion -> Pie Chart (Chart.js) -> Claridad sobre el uso de los $500 USD iniciales.
    - Proyección de Ventas vs Comisiones -> Relationship -> Interactive Calculator + Line Chart (Chart.js) -> Permite a las partes simular escenarios de éxito.
    - Funnel de Ventas -> Order -> Step Cards (HTML/CSS) -> Explica el proceso digital sin usar Mermaid.
    - Protocolo Foto -> Inform -> Interactive Cards -> Detalla la transparencia hacia el cliente.
    Confirmación: NO se utilizaron gráficos SVG ni Mermaid JS. Todo es Canvas y CSS.
-->
<!-- CONFIRMATION: NO SVG graphics used. NO Mermaid JS used. -->

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VA & CO | Dashboard Estratégico Dark Store</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Montserrat:wght@700&display=swap" rel="stylesheet">
    <style>
        :root {
            --ocean-blue: #0A2E50;
            --aqua-teal: #4ECDC4;
            --coral-soft: #F27D52;
            --warm-bg: #FDFBF9;
        }
        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--warm-bg);
            color: #1f2937;
        }
        h1, h2, h3 { font-family: 'Montserrat', sans-serif; }
        .chart-container {
            position: relative;
            width: 100%;
            max-width: 600px;
            margin: auto;
            height: 300px;
        }
        .gradient-border {
            border-image: linear-gradient(to right, var(--ocean-blue), var(--aqua-teal)) 1;
        }
        .step-active {
            border-left: 4px solid var(--aqua-teal);
            background: white;
        }
    </style>
</head>
<body class="antialiased">

    <!-- Header Navigation -->
    <nav class="bg-white/80 backdrop-blur-md sticky top-0 z-50 border-b border-gray-100">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16 items-center">
                <div class="flex items-center gap-2">
                    <div class="w-8 h-8 rounded-full bg-[#0A2E50] flex items-center justify-center text-white font-bold">V</div>
                    <span class="font-extrabold text-ocean-blue tracking-tighter text-xl">VA & CO</span>
                </div>
                <div class="hidden md:flex space-x-8 text-sm font-semibold text-gray-600 uppercase tracking-widest">
                    <a href="#economia" class="hover:text-[#4ECDC4] transition">Economía</a>
                    <a href="#operaciones" class="hover:text-[#4ECDC4] transition">Operaciones</a>
                    <a href="#digital" class="hover:text-[#4ECDC4] transition">Digital</a>
                </div>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <header class="py-16 px-6 max-w-7xl mx-auto text-center">
        <span class="text-aqua-teal font-bold tracking-[0.3em] uppercase text-xs mb-4 block">Relanzamiento 2026</span>
        <h1 class="text-4xl md:text-6xl font-black text-ocean-blue mb-6 leading-tight">
            Transición al Modelo <br> <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#0A2E50] to-[#4ECDC4]">Dark Store Digital</span>
        </h1>
        <p class="max-w-2xl mx-auto text-gray-600 text-lg font-light leading-relaxed">
            Evolución de Pescadería Playa Verde hacia un centro de procesamiento de alta eficiencia y Delivery Premium $100\%$ digital.
        </p>
    </header>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-20 space-y-12">

        <!-- Sección Económica -->
        <section id="economia" class="bg-white rounded-3xl shadow-xl shadow-gray-200/50 overflow-hidden border border-gray-50">
            <div class="p-8 md:p-12">
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
                    <div>
                        <h2 class="text-2xl font-bold text-ocean-blue mb-4">I. Acuerdos y Honorarios</h2>
                        <p class="text-gray-500 mb-8">El modelo de negocio se basa en un crecimiento compartido. La Dirección Estratégica solo prospera si el volumen de venta bruta aumenta.</p>
                        
                        <!-- Calculadora Interactiva -->
                        <div class="bg-gray-50 p-6 rounded-2xl border border-gray-100">
                            <h3 class="text-sm font-bold text-gray-400 uppercase tracking-wider mb-4">Simulador de Comisiones (5% Bruto)</h3>
                            <div class="space-y-4">
                                <div>
                                    <label class="block text-xs font-semibold text-gray-600 mb-1">Venta Bruta Mensual Proyectada (USD)</label>
                                    <input type="range" id="ventaRange" min="2000" max="20000" step="500" value="5000" class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-[#4ECDC4]">
                                    <div class="flex justify-between text-sm font-bold text-ocean-blue mt-2">
                                        <span>$2,000</span>
                                        <span id="ventaDisplay" class="text-xl">$5,000</span>
                                        <span>$20,000</span>
                                    </div>
                                </div>
                                <div class="pt-4 border-t border-gray-200 flex justify-between items-center">
                                    <span class="text-sm text-gray-600">Honorarios Estratégicos (5%):</span>
                                    <span id="comisionDisplay" class="text-2xl font-black text-aqua-teal">$250.00</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="flex flex-col justify-center">
                        <h3 class="text-center text-sm font-bold text-gray-400 uppercase mb-6 tracking-widest">Distribución de Capital Semilla ($500)</h3>
                        <div class="chart-container">
                            <canvas id="capitalChart"></canvas>
                        </div>
                        <p class="text-center text-xs text-gray-400 mt-6 italic">Inversión obligatoria en infraestructura tecnológica para Kommo CRM y edición 4K.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Sección Operativa: La Zona Estéril -->
        <section id="operaciones" class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <div class="md:col-span-2 bg-[#0A2E50] rounded-3xl p-8 md:p-12 text-white relative overflow-hidden">
                <div class="relative z-10">
                    <h2 class="text-3xl font-extrabold mb-6">II. El "Laboratorio Frío"</h2>
                    <p class="text-blue-100 mb-8 max-w-xl">Transformación del local físico en una Zona Estéril de acero inoxidable 304 con iluminación cinematográfica de 6000K.</p>
                    
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div class="bg-white/10 backdrop-blur-sm p-4 rounded-xl border border-white/10">
                            <h4 class="font-bold text-aqua-teal mb-1">Acero Inoxidable</h4>
                            <p class="text-xs text-blue-100">Grado alimenticio para máxima higiene y estética visual en contenido.</p>
                        </div>
                        <div class="bg-white/10 backdrop-blur-sm p-4 rounded-xl border border-white/10">
                            <h4 class="font-bold text-aqua-teal mb-1">Cadena de Frío</h4>
                            <p class="text-xs text-blue-100">Cajas herméticas de acero en motos y cavas térmicas blancas de lujo.</p>
                        </div>
                    </div>
                </div>
                <!-- Decoración abstracta sin SVG -->
                <div class="absolute -bottom-20 -right-20 w-64 h-64 bg-aqua-teal rounded-full opacity-10"></div>
            </div>

            <div class="bg-white rounded-3xl p-8 border border-gray-100 shadow-lg">
                <h3 class="font-bold text-ocean-blue mb-6 border-b pb-4">El Momento WOW</h3>
                <ul class="space-y-6">
                    <li class="flex items-start gap-4">
                        <div class="w-8 h-8 rounded-lg bg-gray-50 flex-shrink-0 flex items-center justify-center font-bold text-ocean-blue">1</div>
                        <div>
                            <p class="font-bold text-sm">Empaque al Vacío</p>
                            <p class="text-xs text-gray-500">Lomos curados sin mermas, listos para cocinar.</p>
                        </div>
                    </li>
                    <li class="flex items-start gap-4">
                        <div class="w-8 h-8 rounded-lg bg-gray-50 flex-shrink-0 flex items-center justify-center font-bold text-ocean-blue">2</div>
                        <div>
                            <p class="font-bold text-sm">Cava Cristalina</p>
                            <p class="text-xs text-gray-500">Hielo transparente y etiquetas oficiales.</p>
                        </div>
                    </li>
                    <li class="flex items-start gap-4">
                        <div class="w-8 h-8 rounded-lg bg-gray-50 flex-shrink-0 flex items-center justify-center font-bold text-ocean-blue">3</div>
                        <div>
                            <p class="font-bold text-sm">Delivery de Cortesía</p>
                            <p class="text-xs text-gray-500">Lead Magnet para captación de nuevos clientes.</p>
                        </div>
                    </li>
                </ul>
            </div>
        </section>

        <!-- Sección Digital -->
        <section id="digital" class="bg-white rounded-3xl shadow-xl p-8 md:p-12 border border-gray-50">
            <div class="text-center mb-12">
                <h2 class="text-3xl font-bold text-ocean-blue mb-4">III. Maquinaria Digital de Ventas</h2>
                <p class="text-gray-500 max-w-2xl mx-auto italic">"Si no está en el CRM, no existe". Kommo es nuestra única fuente de la verdad para liquidación de comisiones.</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
                <div class="p-6 rounded-2xl bg-gray-50 border-t-4 border-ocean-blue">
                    <span class="text-2xl mb-4 block">📢</span>
                    <h4 class="font-bold text-sm mb-2 uppercase">Captación</h4>
                    <p class="text-xs text-gray-500 font-medium">Ads segmentados a público Premium en el Litoral.</p>
                </div>
                <div class="p-6 rounded-2xl bg-gray-50 border-t-4 border-aqua-teal">
                    <span class="text-2xl mb-4 block">🤖</span>
                    <h4 class="font-bold text-sm mb-2 uppercase">Automatización</h4>
                    <p class="text-xs text-gray-500 font-medium">Bot de Instagram califica y deriva a WhatsApp.</p>
                </div>
                <div class="p-6 rounded-2xl bg-white shadow-md border-t-4 border-coral-soft">
                    <span class="text-2xl mb-4 block">📊</span>
                    <h4 class="font-bold text-sm mb-2 uppercase italic">Kommo CRM</h4>
                    <p class="text-xs text-gray-500 font-medium">Cierre de venta y base de datos VIP inalterable.</p>
                </div>
                <div class="p-6 rounded-2xl bg-gray-50 border-t-4 border-ocean-blue">
                    <span class="text-2xl mb-4 block">🛵</span>
                    <h4 class="font-bold text-sm mb-2 uppercase">Despacho</h4>
                    <p class="text-xs text-gray-500 font-medium">Logística con protocolo de foto obligatoria.</p>
                </div>
            </div>
        </section>

        <!-- Protocolo de Curaduría -->
        <section class="bg-gray-100 rounded-3xl p-8 md:p-12 flex flex-col md:flex-row items-center gap-8">
            <div class="flex-1">
                <h2 class="text-2xl font-bold text-ocean-blue mb-4">Protocolo de Transparencia Total</h2>
                <p class="text-gray-600 mb-6">Para eliminar la fricción de la compra digital, el personal debe cumplir el protocolo de envío de fotos antes del despacho:</p>
                <div class="space-y-4">
                    <div class="flex items-center gap-3">
                        <div class="w-2 h-2 rounded-full bg-aqua-teal"></div>
                        <p class="text-sm font-semibold">Foto 1: Corte en tabla de polietileno negra.</p>
                    </div>
                    <div class="flex items-center gap-3">
                        <div class="w-2 h-2 rounded-full bg-aqua-teal"></div>
                        <p class="text-sm font-semibold">Foto 2: Empaque final en cava con hielo.</p>
                    </div>
                </div>
            </div>
            <div class="w-full md:w-72 aspect-video bg-white rounded-2xl border-4 border-dashed border-gray-300 flex flex-col items-center justify-center text-gray-400">
                <span class="text-3xl">📸</span>
                <p class="text-[10px] mt-2 uppercase font-black tracking-widest">Espacio para Visual Media</p>
            </div>
        </section>

    </main>

    <footer class="bg-ocean-blue text-white py-12 px-6">
        <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-6">
            <div class="text-center md:text-left">
                <h3 class="font-bold text-xl mb-1">VA & CO</h3>
                <p class="text-blue-200 text-xs tracking-widest uppercase">Estrategia de Transición Dark Store</p>
            </div>
            <div class="text-xs text-blue-300 text-center md:text-right">
                <p>Catia La Mar, 10 de Junio de 2026</p>
                <p class="mt-1">Propiedad intelectual de la Dirección Estratégica.</p>
            </div>
        </div>
    </footer>

    <script>
        // Lógica de la Calculadora Interactiva
        const ventaRange = document.getElementById('ventaRange');
        const ventaDisplay = document.getElementById('ventaDisplay');
        const comisionDisplay = document.getElementById('comisionDisplay');

        function updateCalculator() {
            const ventaValue = parseInt(ventaRange.value);
            const comisionValue = (ventaValue * 0.05).toFixed(2);
            
            ventaDisplay.innerText = `$${ventaValue.toLocaleString()}`;
            comisionDisplay.innerText = `$${comisionValue}`;
        }

        ventaRange.addEventListener('input', updateCalculator);

        // Configuración de Gráficos (Chart.js)
        const ctxCapital = document.getElementById('capitalChart').getContext('2d');
        
        const capitalChart = new Chart(ctxCapital, {
            type: 'doughnut',
            data: {
                labels: ['Chromebook (Operación CRM)', 'Equipo Edición 4K / Diseño'],
                datasets: [{
                    data: [200, 300],
                    backgroundColor: ['#4ECDC4', '#0A2E50'],
                    hoverOffset: 10,
                    borderWidth: 0
                }]
            },
            options: {
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: {
                            padding: 20,
                            font: { size: 11, family: 'Inter' },
                            usePointStyle: true
                        }
                    },
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                return ` $${context.raw} USD`;
                            }
                        }
                    }
                },
                cutout: '75%'
            }
        });

        // Smooth Scroll para navegación
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                document.querySelector(this.getAttribute('href')).scrollIntoView({
                    behavior: 'smooth'
                });
            });
        });
    </script>
</body>
</html>
